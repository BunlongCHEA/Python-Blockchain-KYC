# Server
HOST=0.0.0.0
PORT=5001
DEBUG=false

# PostgreSQL (must match Go service DB)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=kyc_blockchain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345

# DeepFace
FACE_MODEL=ArcFace
FACE_DETECTOR=retinaface
FACE_THRESHOLD=0.68

# EasyOCR (comma-separated language codes)
# OCR_LANGUAGES=kh,en

# Tesseract language string (khm = Khmer, eng = English)
OCR_LANGUAGES=khm+eng

OCR_GPU=false

# Windows only: full path to tesseract.exe (leave blank on Linux/macOS/Docker)
TESSERACT_CMD=C:/Users/cbunl/AppData/Local/Programs/Tesseract-OCR/tesseract.exe

# KYC scoring thresholds (0-100)
SCORE_VERIFIED=80
SCORE_NEEDS_REVIEW=50