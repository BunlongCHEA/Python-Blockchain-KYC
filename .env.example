# Server
HOST=0.0.0.0
PORT=5001
DEBUG=false

# PostgreSQL (must match Go service DB)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kyc_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# DeepFace
FACE_MODEL=ArcFace
FACE_DETECTOR=retinaface
FACE_THRESHOLD=0.68

# EasyOCR (comma-separated language codes)
OCR_LANGUAGES=km,en
OCR_GPU=false

# KYC scoring thresholds (0-100)
SCORE_VERIFIED=80
SCORE_NEEDS_REVIEW=50