# Server
HOST=0.0.0.0
PORT=5001
DEBUG=false

# PostgreSQL (must match Go service DB)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kyc_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# DeepFace
FACE_MODEL=ArcFace
FACE_DETECTOR=retinaface
FACE_THRESHOLD=0.68

OCR_GPU=false

# EasyOCR (comma-separated language codes)
# OCR_LANGUAGES=kh,en

# Tesseract language string (khm = Khmer, eng = English)
# OCR_LANGUAGES=khm+eng

# Windows only: full path to tesseract.exe (leave blank on Linux/macOS/Docker)
# TESSERACT_CMD=

# Google Credential
GOOGLE_APPLICATION_CREDENTIALS_BASE64=
# GOOGLE_APPLICATION_CREDENTIALS=C:/Users/[name]/Downloads/service-account-key.json
# GOOGLE_PROJECT_ID=gcp-project-id
# GOOGLE_DOCAI_LOCATION=us - asia-southeast1
# GOOGLE_DOCAI_PROCESSOR_ID=document-ai-processor-id

# KYC scoring thresholds (0-100)
SCORE_VERIFIED=80
SCORE_NEEDS_REVIEW=50